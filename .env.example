# =========================
# Azure Blob Storage
# =========================
AZURE_STORAGE_CONNECTION_STRING=your_blob_connection_string
AZURE_BLOB_DOCUMENTS_CONTAINER=documents
AZURE_BLOB_IMAGES_CONTAINER=images
AZURE_BLOB_VIDEOS_CONTAINER=videos
AZURE_BLOB_RAW_CONTAINER=raw

# =========================
# Azure AI Search
# =========================
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-admin-key
AZURE_SEARCH_INDEX_NAME=rag-content-index

# =========================
# Azure OpenAI
# IMPORTANT:
# Use your Azure deployment name here.
# For a lower-cost hackathon demo, text-embedding-3-small is a good default.
# =========================
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com
AZURE_OPENAI_KEY=your-openai-key
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EMBEDDING_DIMENSIONS=1536

# =========================
# App behavior
# =========================
APP_ENV=dev
MAX_CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
